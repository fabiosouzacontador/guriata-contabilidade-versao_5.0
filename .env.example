# ==============================================================================
# VARIÁVEIS DE AMBIENTE
# ==============================================================================
# Copie este arquivo para .env e preencha com seus dados reais
# NUNCA commit o arquivo .env no Git!
# ==============================================================================

# Conexão com Banco de Dados (Neon PostgreSQL)
DATABASE_URL=postgresql://usuario:senha@host:porta/nome_do_banco?sslmode=require

# Senha padrão para usuários de exemplo
SENHA_PADRAO=123

# Ambiente (development, production)
AMBIENTE=development
